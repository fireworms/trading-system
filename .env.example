# Trading System 환경변수 템플릿
# 복사 후 .env로 이름 변경하고 값 채우기: cp .env.example .env

# DB
DATABASE_URL=postgresql://postgres:password@localhost/trading_db

# JWT 서명 키 (랜덤 생성: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Gemini API
GEMINI_API_KEY=

# 텔레그램 봇 (시스템 공용 봇 토큰, chat_id는 DB users.telegram_chat_id에서 관리)
TELEGRAM_BOT_TOKEN=

# KIS API 키는 .env에 저장하지 않음
# DB broker_accounts 테이블에 암호화 저장 → scripts/seed_broker_account.py 로 등록
